

import requests
from google.transit import gtfs_realtime_pb2

# Replace with your GTFS-RT feed URL
feed_url = "https://drtonline.durhamregiontransit.com/gtfsrealtime/VehiclePositions"

# Download the feed
response = requests.get(feed_url)
response.raise_for_status()

# Parse the protobuf
feed = gtfs_realtime_pb2.FeedMessage()
feed.ParseFromString(response.content)

# Iterate through entities
for entity in feed.entity:
    if entity.HasField("vehicle"):
        v = entity.vehicle
        print("Vehicle ID:", v.vehicle.id)
        print("Lat:", v.position.latitude)
        print("Lon:", v.position.longitude)
        print("Timestamp:", v.timestamp)
        print("Stop", v.stops.stop_id)
        print("---")
